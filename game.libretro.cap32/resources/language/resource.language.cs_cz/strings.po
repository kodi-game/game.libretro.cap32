msgctxt "Addon Summary"
msgid "Amstrad - CPC/GX4000 (Caprice32)"
msgstr "Amstrad - CPC/GX4000 (Caprice32)"

msgctxt "Addon Description"
msgid "Caprice32 is an emulator for the Amstrad CPC 8-bit home computer series. It faithfully imitates the CPC464, CPC664, and CPC6128 models."
msgstr "Caprice32 je emulátor řady 8bitových domácích počítačů Amstrad CPC. Věrně napodobuje modely CPC464, CPC664 a CPC6128."

msgctxt "Addon Disclaimer"
msgid "Written by Ulrich Doewich"
msgstr "Napsal Ulrich Doewich"

